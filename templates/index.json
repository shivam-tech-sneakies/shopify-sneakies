    "custom_liquid_KjchYW": {
      "type": "custom-liquid",
      "disabled": true,
      "name": "t:names.custom_liquid",
      "settings": {
        "custom_liquid": "{% comment %}\n  Marquee with Inventory Count Section\n{% endcomment %}\n\n<div class=\"marquee-section-wrapper\">\n  <div class=\"marquee-container\">\n    <div class=\"marquee-content\">\n      {% for product in collections.all.products limit: 10 %}\n        {% assign current_variant = product.selected_or_first_available_variant %}\n        {% if current_variant.inventory_management == \"shopify\" and current_variant.inventory_quantity > 0 %}\n          <span class=\"inventory-item\">\n            🚨 {{ product.title }} - Only {{ current_variant.inventory_quantity }} left in stock!\n          </span>\n        {% endif %}\n      {% endfor %}\n    </div>\n    {% comment %} Duplicate the content for a continuous loop effect {% endcomment %}\n    <div class=\"marquee-content\">\n      {% for product in collections.all.products limit: 10 %}\n        {% assign current_variant = product.selected_or_first_available_variant %}\n        {% if current_variant.inventory_management == \"shopify\" and current_variant.inventory_quantity > 0 %}\n          <span class=\"inventory-item\">\n            🚨 {{ product.title }} - Only {{ current_variant.inventory_quantity }} left in stock!\n          </span>\n        {% endif %}\n      {% endfor %}\n    </div>\n  </div>\n</div>\n\n<style>\n  .marquee-section-wrapper {\n    background-color: #f0f0f0; /* Customize background color */\n    padding: 10px 0;\n    overflow: hidden; /* Hide overflowing content */\n    white-space: nowrap; /* Keep content on a single line */\n  }\n\n  .marquee-container {\n    display: flex;\n    animation: marquee-scroll 20s linear infinite; /* Adjust speed (20s) as needed */\n  }\n\n  .marquee-content {\n    display: inline-block;\n    padding-right: 50px; /* Space between duplicated content */\n  }\n\n  .inventory-item {\n    margin-right: 30px; /* Space between individual product messages */\n    color: #d9534f; /* Customize text color */\n    font-weight: bold;\n  }\n\n  @keyframes marquee-scroll {\n    0% {\n      transform: translateX(0);\n    }\n    100% {\n      transform: translateX(-100%);\n    }\n  }\n</style>",
        "color_scheme": "scheme-ec3d819c-2058-4e68-81e7-2ccfd82c23b6",
        "section_width": "page-width",
        "padding-block-start": 0,
        "padding-block-end": 0
      }
    },
