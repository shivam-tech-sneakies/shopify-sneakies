# Copy this file's contents into Netlify's Site configuration > Environment
# variables. Never commit a real .env file with real values to source control.

# --- Shopify Admin API (read-only) -----------------------------------------
# Custom app in Shopify Admin (Settings > Apps and sales channels > Develop
# apps) with ONLY these scopes: read_customers, read_orders, read_products,
# read_inventory. Do not grant write_orders or write_draft_orders — this
# backend never creates or modifies Shopify orders (see the architecture
# review doc for why).
SHOPIFY_STORE_DOMAIN=sneakies2.myshopify.com
SHOPIFY_ADMIN_API_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_ADMIN_API_VERSION=2026-07

# Sneakies Sample Box variant, numeric form (no gid:// prefix — this is the
# form Shopify webhook payloads use; shopify.js adds the gid:// prefix
# itself where the Admin GraphQL API requires it). Used only for read
# operations: live availability check and identifying past sample-box
# orders during the duplicate-claim check.
# NOTE: this variable was reintroduced during implementation — see
# "Deviations from the architecture doc" in the implementation report.
SHOPIFY_SAMPLE_BOX_VARIANT_ID=47563934072981

# --- Shopify webhook verification -------------------------------------------
# From the webhook subscription's signing secret (Shopify Admin > Settings >
# Notifications > Webhooks, or set when creating the subscription via API).
SHOPIFY_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Klaviyo (private API — server-side only) -------------------------------
# Klaviyo private API key (Account > Settings > API Keys > Private API Keys).
# Different from, and must never be confused with, the public company_id
# already used client-side in assets/sn-klaviyo.js.
KLAVIYO_PRIVATE_API_KEY=pk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
KLAVIYO_COMPANY_ID=X43p2u
KLAVIYO_LAUNCH_LIST_ID=RKXLks

# --- CORS --------------------------------------------------------------------
# Exact origin allowed to call POST /api/precheck-claim. No trailing slash.
ALLOWED_ORIGIN=https://eatsneakies.com
